<%= render FlatPack::Sidebar::Component.new(side: sidebar_side) do |sidebar| %>
  <% sidebar.header do %>
    <%= render FlatPack::Sidebar::Header::Component.new(
      brand_abbr: "RS",
      title: "Root Switchable",
      subtitle: "Recording Studio"
    ) %>
  <% end %>

  <% sidebar.items do %>
    <nav class="py-4 space-y-1" aria-label="Main navigation">
      <%= render FlatPack::Sidebar::Item::Component.new(
        label: "Home",
        href: "/",
        icon: :home
      ) %>

      <%= render FlatPack::Sidebar::Item::Component.new(
        label: "Setup",
        href: "/setup",
        icon: :folder
      ) %>

      <%= render FlatPack::Sidebar::Item::Component.new(
        label: "Config",
        href: "/config",
        icon: :cog_6_tooth
      ) %>

      <%= render FlatPack::Sidebar::Item::Component.new(
        label: "Usage",
        href: "/usage",
        icon: :light_bulb
      ) %>

      <%= render FlatPack::Sidebar::Item::Component.new(
        label: "Switch log",
        href: "/switch_log",
        icon: :server_stack
      ) %>

      <%= render FlatPack::Sidebar::Item::Component.new(
        label: "Method",
        href: "/method",
        icon: :book_open
      ) %>

      <%= render FlatPack::Sidebar::Item::Component.new(
        label: "Gem views",
        href: "/gem_views",
        icon: :folder
      ) %>

    </nav>
  <% end %>

  <% sidebar.footer do %>
    <%= render FlatPack::Sidebar::Footer::Component.new(class: "text-sm text-[var(--surface-muted-content-color)]") do %>
      <%= render FlatPack::Sidebar::Item::Component.new(
        label: "Sign out",
        href: main_app.destroy_user_session_path,
        icon: :lock,
        class: "mx-0",
        data: { turbo_method: :delete }
      ) %>
    <% end %>
  <% end %>
<% end %>
