<%= render FlatPack::TopNav::Component.new do |nav| %>
  <% nav.left do %>
    <%= render FlatPack::Button::Component.new(
      icon: "menu",
      icon_only: true,
      style: :ghost,
      size: :md,
      aria: {label: "Toggle sidebar"},
      data: {
        "flat-pack--sidebar-layout-target": "mobileToggle",
        action: "click->flat-pack--sidebar-layout#toggleMobile"
      },
      class: "md:hidden"
    ) %>

  <% end %>

  <% nav.center do %>
    <div class="hidden text-sm font-medium text-(--surface-muted-content-color) md:block">
      Recording Studio addon template
    </div>
  <% end %>

  <% nav.right do %>
    <% if user_signed_in? %>
      <%= render FlatPack::Avatar::Component.new(
        name: current_user.try(:name).presence || current_user.email,
        size: :sm
      ) %>
    <% end %>
  <% end %>
<% end %>