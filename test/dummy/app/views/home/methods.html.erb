<div class="mx-auto flex w-full max-w-5xl flex-col gap-6">
  <%= render FlatPack::PageTitle::Component.new(
    title: "Method",
    subtitle: "Public gem entry points for reading, resolving, and switching the current root.",
    variant: :h1
  ) %>

  <% @documented_methods.each do |method| %>
    <%= render FlatPack::SectionTitle::Component.new(
      title: method.fetch(:name),
      subtitle: method.fetch(:signature),
      anchor_link: true,
      anchor_id: method.fetch(:anchor)
    ) %>

    <%= render FlatPack::CodeBlock::Component.new(
      title: method.fetch(:signature),
      language: "ruby",
      code: method.fetch(:code)
    ) %>
  <% end %>
</div>