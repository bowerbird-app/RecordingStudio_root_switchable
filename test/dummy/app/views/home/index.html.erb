<div class="mx-auto flex w-full max-w-6xl flex-col gap-6">
  <%= render FlatPack::PageTitle::Component.new(
    title: current_root_recordable&.name || "Recording Studio Root Switchable",
    subtitle: "Use this dummy app to validate actor-aware, device-persisted root switching across multiple scopes.",
    variant: :h1
  ) %>

  <div class="grid gap-6 lg:grid-cols-[minmax(0,2fr)_minmax(320px,1fr)]">
    <%= render FlatPack::Card::Component.new(style: :default) do |card| %>
      <% card.header do %>
        <%= render FlatPack::PageTitle::Component.new(
          title: "What this demo proves",
          subtitle: "The addon stores root selections without mutating recordings, recordables, or events.",
          variant: :h3,
          class: "mb-0 pb-0"
        ) %>
      <% end %>

      <% card.body do %>
        <ol class="space-y-4 text-sm leading-6 text-[var(--surface-content-color)]">
          <li>
            Selections persist per actor, device, and scope in the gem-owned table.
          </li>
          <li>
            Accessible roots are resolved through <code>RecordingStudioAccessible.root_recordings_for</code>.
          </li>
          <li>
            The dedicated v1 page uses FlatPack components instead of a navigation dropdown.
          </li>
          <li>
            If a saved root falls out of scope or access, resolution falls back to the configured default accessible root.
          </li>
        </ol>
      <% end %>

      <% card.footer do %>
        <div class="flex flex-wrap gap-3">
          <%= link_to recording_studio_root_switchable.root_switch_path(scope: "all_workspaces"), class: "inline-flex" do %>
            <%= render FlatPack::Button::Component.new(text: "Open all-workspaces scope", style: :primary, size: :md) %>
          <% end %>

          <%= link_to recording_studio_root_switchable.root_switch_path(scope: "client_workspaces"), class: "inline-flex" do %>
            <%= render FlatPack::Button::Component.new(text: "Open client-workspaces scope", style: :secondary, size: :md) %>
          <% end %>
        </div>
      <% end %>
    <% end %>

    <div class="flex flex-col gap-6">
      <%= render FlatPack::Card::Component.new(style: :outlined) do |card| %>
        <% card.header do %>
          <%= render FlatPack::PageTitle::Component.new(
            title: "Current request state",
            subtitle: "Resolved from the signed-in actor plus the encrypted device key cookie.",
            variant: :h3,
            class: "mb-0 pb-0"
          ) %>
        <% end %>

        <% card.body do %>
          <dl class="space-y-3 text-sm">
            <div>
              <dt class="text-[var(--surface-muted-content-color)]">Actor</dt>
              <dd class="font-medium"><%= current_user.email %></dd>
            </div>
            <div>
              <dt class="text-[var(--surface-muted-content-color)]">Scope</dt>
              <dd class="font-medium"><%= current_root_scope_key || "Not resolved" %></dd>
            </div>
            <div>
              <dt class="text-[var(--surface-muted-content-color)]">Current root</dt>
              <dd class="font-medium"><%= current_root_recordable&.name || "None selected" %></dd>
            </div>
            <div>
              <dt class="text-[var(--surface-muted-content-color)]">Device key</dt>
              <dd class="font-mono text-xs"><%= current_root_device_key_preview %></dd>
            </div>
          </dl>
        <% end %>
      <% end %>

      <%= render FlatPack::Card::Component.new(style: :outlined) do |card| %>
        <% card.header do %>
          <%= render FlatPack::PageTitle::Component.new(
            title: "Configured scopes",
            subtitle: "This dummy app seeds multiple accessible roots to demonstrate per-scope behavior.",
            variant: :h3,
            class: "mb-0 pb-0"
          ) %>
        <% end %>

        <% card.body do %>
          <div class="space-y-4 text-sm">
            <% @scope_rows.each do |row| %>
              <div class="rounded-xl border border-[var(--surface-border-color)] p-4">
                <div class="flex items-center justify-between gap-3">
                  <div>
                    <p class="font-semibold"><%= row[:scope_label] %></p>
                    <p class="text-[var(--surface-muted-content-color)]"><%= row[:scope_description] %></p>
                  </div>

                  <% if row[:scope_key] == current_root_scope_key %>
                    <%= render FlatPack::Badge::Component.new(text: "Active request scope", style: :success, size: :sm) %>
                  <% end %>
                </div>

                <p class="mt-3"><strong>Current root:</strong> <%= row[:current_root_label] || "None available" %></p>
                <p><strong>Resolved via:</strong> <%= row[:selected_via] %></p>
                <p><strong>Available roots:</strong> <%= row[:available_roots].presence&.join(", ") || "None" %></p>
              </div>
            <% end %>
          </div>
        <% end %>
      <% end %>
    </div>
  </div>
</div>
